{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(index.html|app.js|styles.css|sw.js|manifest.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
